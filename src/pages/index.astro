---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../data/config.json';

// 1. Helper function to format dates exactly how Google Calendar requires (YYYYMMDDTHHMMSSZ)
const formatGCalDate = (isoString) => {
    const date = new Date(isoString);
    return date.toISOString().replace(/-|:|\.\d\d\d/g, '');
};

// 2. Build the URL parameters dynamically
const gCalDates = `${formatGCalDate(siteConfig.eventStart)}/${formatGCalDate(siteConfig.eventEnd)}`;
const eventTitle = `${siteConfig.year} Hudson Valley Portfolio Review`;
const eventLocation = `${siteConfig.location.name}, ${siteConfig.location.address1}, ${siteConfig.location.address2}`;

// 3. Construct the final link
const calendarLink = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(eventTitle)}&dates=${gCalDates}&details=${encodeURIComponent(siteConfig.calendarDescription)}&location=${encodeURIComponent(eventLocation)}`;
---

<Layout 
    title={`Hudson Valley Portfolio Reviews ${siteConfig.year}`} 
    description="A community event for emerging designers to get feedback on their portfolios, resumes, etc. as they prepare to apply to their first ever full time role in the design industry."
	isHome={true}
>
    <section id="info">
        <h2>Event Information</h2>
        <h3>Date & Time</h3>
        <p><strong>{siteConfig.date}</strong> <br> {siteConfig.time}</p>
        
        <a href={calendarLink} target="_blank" rel="noopener noreferrer" title="Save Event in Google Calendar">Add to Google Calendar</a>

        <h3>Location</h3>
        <p id="location">
            <strong>{siteConfig.location.name}</strong> <br>
            {siteConfig.location.address1} <br>
            {siteConfig.location.address2}
        </p>
        <div style="text-decoration:none; overflow:hidden;max-width:100%;width:100%;height:200px;">
            <div id="gmap-canvas" style="height:100%; width:100%;max-width:100%;">
                <iframe aria-labelledby="location" style="height:100%;width:100%;" frameborder="0" src={siteConfig.location.mapEmbedUrl}></iframe>
            </div>
        </div>
    </section>
    
    <section id="about">
        <h2>About</h2>
        <p>
            The review is a chance for emerging designers (students, recent graduates, career switchers, bootcamp graduates, anyone early in their design career) to practice their interviewing skills and get valuable feedback from local professionals about their design work and resume in a no-risk, non-competitive environment geared at preparing them for the professional portfolio presentation process. Participants also have the opportunity to network and share their work with each other.
        </p>
    </section>

    <section id="register">
        <h2>Register as a volunteer reviewer</h2>
        <p>
            Reviewers of all levels of experience welcome! We ask that you have at least one year of work experience in the design field. 
			It helps our reviewees to get to speak both to leaders and hiring managers, but the folks who broke into the industry recently have a helpful perspective, too! 
			By registering, you agree to abide by the event <a href={`${import.meta.env.BASE_URL}/coc`}>Code of Conduct</a>..
        </p>
        
        <iframe width="640px" height="480px" aria-label="reviewer registration form"
            src={siteConfig.registrationFormUrl}
            frameborder="0" marginwidth="0" marginheight="0" style="max-width:100%; max-height:100vh"
            allowfullscreen webkitallowfullscreen mozallowfullscreen msallowfullscreen> </iframe>
    </section>
</Layout>