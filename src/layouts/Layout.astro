---
import '../styles/global.css';
import siteConfig from '../data/config.json'; 

const { title, description, isHome = false } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>{title}</title>
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:url" content={`https://npz-web.github.io${import.meta.env.BASE_URL}`}>
    
    <meta property="og:image" content={`https://npz-web.github.io${import.meta.env.BASE_URL}${siteConfig.images.ogImage}`}>
    
    <meta name="description" content={description}>
    <meta name="author" content="Shauna Keating">
    
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/favicon.ico`}>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <style is:inline set:html={`
        @import url('https://fonts.googleapis.com/css2?family=Inclusive+Sans:ital,wght@0,300..700;1,300..700&display=swap');
        @import url('${siteConfig.theme.fontUrl}');
    `}></style>

    <link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6DRD89LYWB"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-6DRD89LYWB');
    </script>
</head>
<body>
    <header>
        <h1>{siteConfig.year} Hudson Valley Portfolio Review</h1>
        <nav>
            {isHome ? (
                <>
                    <a href="#info">Event Info</a>
                    <a href="#about">About</a>
                    <a href="#register">Register</a>
                </>
            ) : (
                <a href={import.meta.env.BASE_URL}>Return Home</a>
            )}
            
            <a href="#top">Back to Top</a>
        </nav>
    </header>
    <div id="top"></div>
    
    <main>
        <slot />
    </main>

    <footer>
        <p>Copyright © {siteConfig.year} Shauna Keating All Rights Reserved</p>
        <p>Built with Astro, styled by extending <a href="https://simplecss.org" target="_blank" rel="noopener noreferrer">Simple.css</a>. Hosted and deployed on Github Pages.</p>
        <p><a href="https://fonts.google.com/specimen/Inclusive+Sans" target="_blank" rel="noopener noreferrer">Inclusive Sans</a> & <a href={`https://fonts.google.com/specimen/${siteConfig.theme.displayFontFamily.replace(/ /g, '+')}`} target="_blank" rel="noopener noreferrer">{siteConfig.theme.displayFontFamily}</a> served over Google Fonts.</p>
    </footer>
</body>
</html>

<style is:global define:vars={{ 
    bgImage: `url('${import.meta.env.BASE_URL}${siteConfig.images.background}')`,
    displayFont: `"${siteConfig.theme.displayFontFamily}", serif`
}}>
    body {
        background-image: var(--bgImage);
    }

    h1, h2 {
        font-family: var(--displayFont);
    }
</style>